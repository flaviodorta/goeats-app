generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MenuTab {
  popular
  mains
  drinks
  desserts
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  delivered
  cancelled
  rejected
}

enum PaymentMethod {
  credit
  debit
  pix
  cash
}

model Category {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  restaurants RestaurantCategory[]

  @@map("categories")
}

model RestaurantCategory {
  restaurant_id Int
  category_id   Int

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  category   Category   @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([restaurant_id, category_id])
  @@map("restaurant_categories")
}

model Restaurant {
  id            Int                  @id @default(autoincrement())
  name          String
  rating        Float
  delivery_fee  String
  delivery_time String
  distance      String
  icon_name     String
  icon_color    String
  promoted      Boolean              @default(false)
  cover_image   String?
  created_at    DateTime             @default(now())
  updated_at    DateTime             @updatedAt

  categories    RestaurantCategory[]
  menu_items    MenuItem[]
  orders        Order[]

  @@map("restaurants")
}

model MenuItem {
  id            Int         @id @default(autoincrement())
  restaurant_id Int
  name          String
  description   String
  price         Float
  tab           MenuTab
  icon_name     String
  image         String?
  rating        Float?
  created_at    DateTime    @default(now())

  restaurant    Restaurant  @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  order_items   OrderItem[]

  @@map("menu_items")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  password_hash String
  phone         String    @default("")
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  addresses     Address[]
  orders        Order[]

  @@map("users")
}

model Address {
  id           Int      @id @default(autoincrement())
  user_id      Int
  label        String   @default("Casa")
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String   @default("SP")
  zip_code     String
  is_default   Boolean  @default(false)
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Order {
  id             Int           @id @default(autoincrement())
  user_id        Int
  restaurant_id  Int
  current_status OrderStatus   @default(pending)
  payment_method PaymentMethod
  subtotal       Float
  delivery_fee   Float
  discount       Float         @default(0)
  total          Float
  coupon_code    String?

  address_street       String
  address_number       String
  address_complement   String?
  address_neighborhood String
  address_city         String
  address_state        String
  address_zip_code     String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user       User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  restaurant Restaurant           @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  items      OrderItem[]
  history    OrderStatusHistory[]

  @@map("orders")
}

model OrderItem {
  id           Int    @id @default(autoincrement())
  order_id     Int
  menu_item_id Int
  name         String
  price        Float
  quantity     Int

  order     Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  menu_item MenuItem @relation(fields: [menu_item_id], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model OrderStatusHistory {
  id         Int         @id @default(autoincrement())
  order_id   Int
  status     OrderStatus
  actor      String
  actor_id   Int?
  note       String?
  created_at DateTime    @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}
