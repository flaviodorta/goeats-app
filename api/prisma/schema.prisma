generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MenuTab {
  popular
  mains
  drinks
  desserts
}

model Category {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  restaurants RestaurantCategory[]

  @@map("categories")
}

model RestaurantCategory {
  restaurant_id Int
  category_id   Int

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  category   Category   @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([restaurant_id, category_id])
  @@map("restaurant_categories")
}

model Restaurant {
  id            Int                  @id @default(autoincrement())
  name          String
  rating        Float
  delivery_fee  String
  delivery_time String
  distance      String
  icon_name     String
  icon_color    String
  promoted      Boolean              @default(false)
  cover_image   String?
  created_at    DateTime             @default(now())
  updated_at    DateTime             @updatedAt

  categories    RestaurantCategory[]
  menu_items    MenuItem[]

  @@map("restaurants")
}

model MenuItem {
  id            Int        @id @default(autoincrement())
  restaurant_id Int
  name          String
  description   String
  price         Float
  tab           MenuTab
  icon_name     String
  image         String?
  rating        Float?
  created_at    DateTime   @default(now())

  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@map("menu_items")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  password_hash String
  phone         String    @default("")
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  addresses     Address[]

  @@map("users")
}

model Address {
  id           Int      @id @default(autoincrement())
  user_id      Int
  label        String   @default("Casa")
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String   @default("SP")
  zip_code     String
  is_default   Boolean  @default(false)
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("addresses")
}
